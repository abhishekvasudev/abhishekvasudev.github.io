{
  "name": "portfolio-blog",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:content && vite",
    "build:content": "node scripts/build-content.mjs",
    "build:assets": "node scripts/generate-assets.mjs",
    "build": "npm run build:content && npm run build:assets && tsc --noEmit && vite build && node scripts/prerender.mjs && node scripts/generate-sitemap.mjs && node scripts/generate-rss.mjs && node scripts/verify-dist.mjs",
    "preview": "vite preview --port 4173"
  },
  "dependencies": {
    "fuse.js": "^7.0.0",
    "lucide-react": "^1.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "rehype-highlight": "^7.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "unified": "^11.0.5",
    "vite": "^6.0.5",
    "vite-plugin-sitemap": "^0.8.2"
  }
}
